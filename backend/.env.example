# Environment Configuration Template
# Copy this file to .env and fill in your values

# Environment Settings
ENVIRONMENT=development  # development, staging, production
DEBUG=True
SECRET_KEY=your-secret-key-here

# Database Configuration (PostgreSQL)
DB_NAME=azuum_form_hub_dev
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432

# Production Database (AWS RDS)
# DB_NAME=azuum_form_hub_prod
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password
# DB_HOST=your-rds-endpoint.rds.amazonaws.com
# DB_PORT=5432

# Cache Configuration (Redis)
REDIS_URL=redis://127.0.0.1:6379/1
REDIS_PASSWORD=

# Production Cache (AWS ElastiCache)
# REDIS_URL=redis://your-elasticache-endpoint:6379/1
# REDIS_PASSWORD=your_redis_password

# Email Configuration (AWS SES)
EMAIL_HOST=email-smtp.amazonaws.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-ses-smtp-username
EMAIL_HOST_PASSWORD=your-ses-smtp-password
DEFAULT_FROM_EMAIL=noreply@azuumformhub.com

# AWS Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_STORAGE_BUCKET_NAME=your_s3_bucket_name
AWS_S3_REGION_NAME=us-east-1

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# Feature Flags
FEATURE_ADVANCED_SEARCH=True
FEATURE_FILE_VERSIONING=True
FEATURE_BULK_OPERATIONS=True
FEATURE_API_CACHING=True
FEATURE_SECURITY_LOGGING=True

# Monitoring and Logging
PERFORMANCE_MONITORING=False
HEALTH_CHECK_ENABLED=True
SENTRY_DSN=
SENTRY_TRACE_SAMPLE_RATE=0.1

# Logging
LOG_FILE=/var/log/django/app.log
AWS_LOG_GROUP=django-app
AWS_LOG_STREAM=production

# API Configuration
API_VERSION=1.0
APP_VERSION=1.0.0

# Security Settings
ACCOUNT_LOCKOUT_THRESHOLD=5
ACCOUNT_LOCKOUT_DURATION=900
ACCOUNT_LOCKOUT_COOLDOWN=300

# File Upload Settings
MAX_UPLOAD_SIZE=52428800  # 50MB in bytes

# Rate Limiting
RATELIMIT_ENABLE=True
RATELIMIT_DEFAULT=1000/h
RATELIMIT_ADMIN=5000/h
RATELIMIT_PREMIUM=2000/h
RATELIMIT_STANDARD=1000/h
RATELIMIT_AUTH=10/m
RATELIMIT_UPLOAD=50/h
RATELIMIT_EXPORT=20/h
